/*
 * Workflow tests for main_cellranger.nf using nf-core/scrnaseq test data
 * (homo_sapiens genome + GTF, the same reference the scrnaseq cellranger/mkref
 * module test uses). Real runs require the proprietary Cell Ranger image
 * (e.g. quay.io/cumulus/cellranger:10.0.0), supplied via --container.
 */
nextflow_workflow {
    name "Test workflow main_cellranger"
    script "../../main_cellranger.nf"
    config "../config/nextflow.config"

    tag "index"
    tag "cellranger"

    test("Cell Ranger mkref with nf-core homo_sapiens genome and GTF - stub") {
        tag "stub"
        options "-stub"

        when {
            params {
                fasta  = 'https://raw.githubusercontent.com/nf-core/test-datasets/modules/data/genomics/homo_sapiens/genome/genome.fasta'
                gtf    = 'https://raw.githubusercontent.com/nf-core/test-datasets/modules/data/genomics/homo_sapiens/genome/genome.gtf'
                outdir = "$outputDir"
            }
        }

        then {
            assert workflow.success
            assert snapshot(workflow.trace.succeeded().size()).match()
        }
    }

    test("Cell Ranger mkref with nf-core homo_sapiens genome and GTF") {
        when {
            params {
                fasta  = 'https://raw.githubusercontent.com/nf-core/test-datasets/modules/data/genomics/homo_sapiens/genome/genome.fasta'
                gtf    = 'https://raw.githubusercontent.com/nf-core/test-datasets/modules/data/genomics/homo_sapiens/genome/genome.gtf'
                outdir = "$outputDir"
            }
        }

        then {
            assert workflow.success
            assert workflow.trace.succeeded().size() >= 1
        }
    }
}
