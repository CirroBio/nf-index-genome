/*
 * Workflow tests for main_alevinfry.nf using nf-core/scrnaseq test data
 * (homo_sapiens genome + GTF, the same reference the scrnaseq simpleaf/index
 * module test uses).
 */
nextflow_workflow {
    name "Test workflow main_alevinfry"
    script "../../main_alevinfry.nf"
    config "../config/nextflow.config"

    tag "index"
    tag "alevinfry"

    test("alevin-fry (simpleaf) index with nf-core homo_sapiens genome and GTF - stub") {
        tag "stub"
        options "-stub"

        when {
            params {
                fasta  = 'https://raw.githubusercontent.com/nf-core/test-datasets/modules/data/genomics/homo_sapiens/genome/genome.fasta'
                gtf    = 'https://raw.githubusercontent.com/nf-core/test-datasets/modules/data/genomics/homo_sapiens/genome/genome.gtf'
                outdir = "$outputDir"
            }
        }

        then {
            assert workflow.success
            assert snapshot(workflow.trace.succeeded().size()).match()
        }
    }

    test("alevin-fry (simpleaf) index with nf-core homo_sapiens genome and GTF") {
        when {
            params {
                fasta  = 'https://raw.githubusercontent.com/nf-core/test-datasets/modules/data/genomics/homo_sapiens/genome/genome.fasta'
                gtf    = 'https://raw.githubusercontent.com/nf-core/test-datasets/modules/data/genomics/homo_sapiens/genome/genome.gtf'
                outdir = "$outputDir"
            }
        }

        then {
            assert workflow.success
            assert workflow.trace.succeeded().size() >= 1
        }
    }
}
