/*
 * Workflow tests for main_kallisto.nf using nf-core test data (sarscov2 genome + GTF).
 */
nextflow_workflow {
    name "Test workflow main_kallisto"
    script "../../main_kallisto.nf"
    config "../config/nextflow.config"

    tag "index"
    tag "kallisto"

    test("Kallisto genome index only (no GTF) - stub") {
        tag "stub"
        options "-stub"

        when {
            params {
                fasta  = 'https://raw.githubusercontent.com/nf-core/test-datasets/modules/data/genomics/sarscov2/genome/genome.fasta'
                outdir = "$outputDir"
            }
        }

        then {
            assert workflow.success
            assert snapshot(workflow.trace.succeeded().size()).match()
        }
    }

    test("Kallisto genome index only (no GTF)") {
        when {
            params {
                fasta  = 'https://raw.githubusercontent.com/nf-core/test-datasets/modules/data/genomics/sarscov2/genome/genome.fasta'
                outdir = "$outputDir"
            }
        }

        then {
            assert workflow.success
            assert workflow.trace.succeeded().size() >= 1
        }
    }

    test("Kallisto genome + transcriptome index (with GTF, gffread) - stub") {
        tag "stub"
        options "-stub"

        when {
            params {
                fasta  = 'https://raw.githubusercontent.com/nf-core/test-datasets/modules/data/genomics/sarscov2/genome/genome.fasta'
                gtf    = 'https://raw.githubusercontent.com/nf-core/test-datasets/modules/data/genomics/sarscov2/genome/genome.gtf'
                outdir = "$outputDir"
            }
        }

        then {
            assert workflow.success
            assert snapshot(workflow.trace.succeeded().size()).match()
        }
    }

    test("Kallisto genome + transcriptome index (with GTF, gffread)") {
        when {
            params {
                fasta  = 'https://raw.githubusercontent.com/nf-core/test-datasets/modules/data/genomics/sarscov2/genome/genome.fasta'
                gtf    = 'https://raw.githubusercontent.com/nf-core/test-datasets/modules/data/genomics/sarscov2/genome/genome.gtf'
                outdir = "$outputDir"
            }
        }

        then {
            assert workflow.success
            assert workflow.trace.succeeded().size() >= 1
        }
    }

    test("Kallisto genome + transcriptome index (with GTF, rsem) - stub") {
        tag "stub"
        options "-stub"

        when {
            params {
                fasta                = 'https://raw.githubusercontent.com/nf-core/test-datasets/modules/data/genomics/sarscov2/genome/genome.fasta'
                gtf                  = 'https://raw.githubusercontent.com/nf-core/test-datasets/modules/data/genomics/sarscov2/genome/genome.gtf'
                transcriptome_source = 'rsem'
                outdir               = "$outputDir"
            }
        }

        then {
            assert workflow.success
            assert snapshot(workflow.trace.succeeded().size()).match()
        }
    }
}
